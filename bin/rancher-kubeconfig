#!/usr/bin/env bash
# Fetch kubeconfigs for every active Rancher cluster, merge them, and rewrite
# each user entry to use a single Rancher API token as a static bearer. The
# resulting kubeconfig works for all clusters without per-cluster browser auth.
#
# Token sources, in order:
#   1. $RANCHER_API_TOKEN
#   2. first positional argument
#   3. stdin (if not a tty)
# Token format: "token-xxxxx:longrandomstring" from Rancher UI -> Account & API
# Keys -> Create API Key (no scope, lifetime of your choice).
#
# Output path defaults to ~/.kube/config; override with -o <path> or KUBECONFIG_OUT.

set -euo pipefail

out="${KUBECONFIG_OUT:-$HOME/.kube/config}"
token="${RANCHER_API_TOKEN:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -o|--output) out="$2"; shift 2 ;;
    -h|--help)
      awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} /^$/{print; next} {exit}' "$0"
      exit 0 ;;
    -*) echo "unknown flag: $1" >&2; exit 2 ;;
    *) token="$1"; shift ;;
  esac
done

if [[ -z "$token" && ! -t 0 ]]; then
  read -r token
fi
if [[ -z "$token" ]]; then
  echo "error: no Rancher API token provided" >&2
  echo "usage: RANCHER_API_TOKEN=token-xxx:yyy $(basename "$0") [-o path]" >&2
  exit 2
fi

for cmd in rancher kubectl yq; do
  command -v "$cmd" >/dev/null || { echo "error: $cmd not in PATH" >&2; exit 1; }
done

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT
mkdir -p "$tmp/configs"

echo "Listing active Rancher clusters..." >&2
rancher clusters ls --format '{{.Cluster.ID}} {{.Cluster.State}} {{.Cluster.Name}}' \
  | awk '$2=="active" {print $1, $3}' > "$tmp/clusters.txt"
total=$(wc -l < "$tmp/clusters.txt" | tr -d ' ')
echo "Found $total active clusters" >&2

i=0
fails=0
while read -r id name; do
  i=$((i+1))
  printf "[%d/%d] %s\n" "$i" "$total" "$name" >&2
  if ! rancher clusters kubeconfig "$id" \
        > "$tmp/configs/${name}.yaml" 2>"$tmp/configs/${name}.err"; then
    echo "  fetch failed: $(cat "$tmp/configs/${name}.err")" >&2
    fails=$((fails+1))
    rm -f "$tmp/configs/${name}.yaml"
  fi
done < "$tmp/clusters.txt"

merged_count=$(find "$tmp/configs" -name '*.yaml' | wc -l | tr -d ' ')
echo "Merging $merged_count kubeconfigs..." >&2
kc_list=$(find "$tmp/configs" -name '*.yaml' | paste -sd: -)
KUBECONFIG="$kc_list" kubectl config view --flatten --raw > "$tmp/merged.yaml"

echo "Rewriting users to use API token..." >&2
if yq --version 2>&1 | grep -q mikefarah; then
  TOKEN="$token" yq '(.users[].user) = {"token": strenv(TOKEN)}' \
    "$tmp/merged.yaml" > "$tmp/final.yaml"
else
  yq -y --arg token "$token" '.users |= map(.user = {token: $token})' \
    "$tmp/merged.yaml" > "$tmp/final.yaml"
fi

grep -q "^apiVersion: v1" "$tmp/final.yaml" || {
  echo "error: final config does not look like a kubeconfig" >&2
  exit 1
}

mkdir -p "$(dirname "$out")"
install -m 600 "$tmp/final.yaml" "$out"

contexts=$(KUBECONFIG="$out" kubectl config get-contexts -o name | wc -l | tr -d ' ')
echo "Wrote $out ($contexts contexts)" >&2
if (( fails > 0 )); then
  echo "Note: $fails clusters failed to fetch" >&2
fi
